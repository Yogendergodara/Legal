# temp_java_sync — Dev UI + E2E (mirror review/review_agent/.env)
# Copy to .env and set LLM_API_KEY. Dev UI reads this file only (not review_agent/.env).

DOCUMENT_SERVER_URL=http://localhost:8003
DATABASE_URL=postgresql://legalai:legalai@127.0.0.1:5435/legalai

E2E_TENANT_ID=e2e-demo
ATLASSIAN_TEST_TENANT_ID=atlassian-test-run
DEV_UI_PORT=8090
PLATFORM_URL=http://localhost:8080

LLM_PROVIDER=openai
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
LLM_KEY_POOL_ENABLED=false
GROQ_API_KEY=
LLM_API_KEY=
COMPLIANCE_LLM_TEMPERATURE=0
COMPLIANCE_LLM_MAX_TOKENS=8192

REVIEW_MIN_SECTION_CHARS=40
REVIEW_POLICY_SCOPE=request
REVIEW_PREFLIGHT_ENABLED=true
GUARD_PASS_ENABLED=true
FINAL_GAP_VERIFY_ENABLED=true

DISCOVERY_MAX_POLICIES=0
SECTION_COMPARE_BATCH_SIZE=8
SECTION_COMPARE_CONCURRENCY=2
COMPARE_MAX_POLICY_HITS=3

LLM_GLOBAL_CONCURRENCY=2
OBLIGATION_COMPARE_BATCH_SIZE=16
REVIEW_PIPELINE_MODE=parallel_hybrid
OBLIGATION_ROUTING_ENABLED=true
OBLIGATION_ROUTING_TENANT_ALLOWLIST=

MCP_GLOBAL_CONCURRENCY=6
OBLIGATION_RETRIEVAL_CONCURRENCY=4
EVIDENCE_EXPAND_CONCURRENCY=2

RETRIEVAL_MEANING_FIRST_ENABLED=true
RETRIEVAL_CATEGORY_HARD_FILTER=false
EVIDENCE_RERANK_BYPASS_ENABLED=true
CATALOG_MATCH_TOP_K=12
MAX_OBLIGATIONS_PER_REVIEW=200

OBLIGATION_COMPARE_PROMPT_V2_ENABLED=false
IPC3_BOILERPLATE_SUBSTANTIVE_OVERRIDE_ENABLED=false
EVIDENCE_SEMANTIC_OVERLAP_ENABLED=false

# Optional — multi-key rotation for battery scripts only (not Dev UI)
# LLM_KEY_POOL_ENABLED=true
# LLM_API_KEYS=key1,key2,key3
