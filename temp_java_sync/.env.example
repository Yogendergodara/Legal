# Point at running document-mcp (default local port)
DOCUMENT_SERVER_URL=http://localhost:8003

# Same DB as document_core (for optional direct checks)
DATABASE_URL=postgresql://legalai:legalai@127.0.0.1:5435/legalai

# Review LLM (real E2E — set your key)
LLM_PROVIDER=mistralai
LLM_API_KEY=
LLM_MODEL=mistral-small-latest

# Prod-like review gates (match staging)
REVIEW_REQUIRE_CONTRACT_DOCUMENT_ID=true
REVIEW_REJECT_INLINE_POLICIES=true
REVIEW_POLICY_SCOPE=request
REVIEW_PREFLIGHT_ENABLED=true
GUARD_PASS_ENABLED=true
FINAL_GAP_VERIFY_ENABLED=true

# Review pipeline (non-LLM) — match review_agent/.env.example for faithful E2E
DISCOVERY_MAX_POLICIES=0
DISCOVERY_GROUP_CAP_MODE=adaptive
DISCOVERY_MIN_POLICY_GROUPS=6
DISCOVERY_MAX_POLICY_GROUPS_CEILING=20
SECTION_CLASSIFY_MODE=lexical_first
COMPARE_POLICY_HIT_MODE=category_aligned
COMPARE_MAX_POLICY_HITS=3
# PF-1A / IPC-0 — hybrid performance (see review/plans/PHASE_IPC0_CONFIG_IMPLEMENTATION_PLAN.md)
LLM_GLOBAL_CONCURRENCY=2
LLM_RATE_LIMIT_MAX_RETRIES=3
SECTION_COMPARE_CONCURRENCY=2
OBLIGATION_COMPARE_BATCH_SIZE=6
OBLIGATION_SECTION_CUTOVER_MODE=ipc_fallback
OBLIGATION_RETRIEVAL_CONCURRENCY=8
MAX_OBLIGATIONS_PER_REVIEW=80
MAX_OBLIGATIONS_PER_SECTION=8
OBLIGATION_CAP_MODE=round_robin
MAX_PLANNER_CALLS_PER_REVIEW=60
# PF-1B — obligation retrieval efficiency (Tier 2)
OBLIGATION_RETRIEVAL_ADAPTIVE_LADDER=true
OBLIGATION_RETRIEVAL_PARALLEL_QUERIES=true
EVIDENCE_EXPAND_CONCURRENCY=4
# PF-1C — parallel hybrid + obligation routing (all tenants; leave allowlists empty)
REVIEW_PIPELINE_MODE=parallel_hybrid
OBLIGATION_ROUTING_ENABLED=true
# OBLIGATION_ROUTING_TENANT_ALLOWLIST=
# OBLIGATION_ROUTING_TENANT_DENYLIST=
# REVIEW_PIPELINE_TENANT_ALLOWLIST=
# Golden battery scripts set GOLDEN_LLM_PROFILE_FORCE=true to override LLM_RATE_LIMIT_PROFILE=default
# GOLDEN_LLM_PROFILE_FORCE=true
# BATTERY_SKIP_CISCO=1
OBLIGATION_RETRIEVAL_SKIP_RESOLVED_SECTIONS=false
OBLIGATION_SKIP_RESOLVED_PARALLEL_GUARD=true
OBLIGATION_RETRIEVAL_SECTION_HIT_REUSE=true
# Rollback: REVIEW_PIPELINE_MODE=serial
# PF-1D — MCP cache + HTTP pool + compare batches
MCP_SEARCH_CACHE_ENABLED=true
MCP_HTTP_MAX_KEEPALIVE_CONNECTIONS=40
MCP_HTTP_MAX_CONNECTIONS=100
SECTION_COMPARE_BATCH_SIZE=4

# SR-01 — meaning-first retrieval (tag-second precision); see PHASE_SR01_MEANING_FIRST_RETRIEVAL_PLAN.md
RETRIEVAL_MEANING_FIRST_ENABLED=true
RETRIEVAL_CATEGORY_HARD_FILTER=false
RETRIEVAL_SECTION_QUERY_MAX_CHARS=2000
COMPARE_HIT_ALLOW_PRIMARY_FALLBACK=true
# SR01_RETRIEVAL_OPT_OUT=true
# SR01_AB_MODE=full  # run_retrieval_ab_atlassian.py: baseline + SR-01

# OB-04 — obligation evidence gates (PHASE_OB01020304)
EVIDENCE_MIN_CONCEPT_OVERLAP=0.15
ROUTING_COMPARE_MIN_CONFIDENCE=0.75

# PR-01 — precision funnel recovery (PHASE_PR01_PRECISION_FUNNEL_RECOVERY_PLAN.md)
EVIDENCE_RERANK_BYPASS_ENABLED=true
EVIDENCE_RERANK_BYPASS_MIN_CONFIDENCE=0.55
EVIDENCE_EXPAND_MAX_ROUNDS=2
EVIDENCE_EXPAND_BROADEN_MODE=both
EVIDENCE_EXPAND_MAX_EXTRA_DOCS=3
CATALOG_MATCH_TOP_K=12
CATALOG_MATCH_MAX_CANDIDATES=8
MAX_CATALOG_SEARCH_CALLS_PER_REVIEW=150
OBLIGATION_RETRIEVAL_UNION_TOP_K=20
OBLIGATION_RETRIEVAL_MAX_QUERIES=4
OBLIGATION_COMPARE_MAX_OBLIGATION_CHARS=3000
PLAYBOOK_COMPARE_MAX_CHARS=2000
ROUTING_PLANNER_EXPLICIT_MENTION_CONFIDENCE_FLOOR=0.55

# --- Mistral dev (429-safe) — uncomment if review/sync hits HTTP 429 ---
# LLM_GLOBAL_CONCURRENCY=1
# SECTION_COMPARE_CONCURRENCY=1
# SECTION_CLASSIFY_BATCH_SIZE=1
# LLM_RATE_LIMIT_MAX_RETRIES=5
# LLM_RATE_LIMIT_BACKOFF_MAX_SECONDS=60

# TEMP Phase B — rotate across 3 Mistral keys on HTTP 429 (remove later)
# LLM_KEY_POOL_ENABLED=true
# LLM_API_KEYS=your-key-1,your-key-2,your-key-3

# E2E tenant (isolated from real data)
E2E_TENANT_ID=e2e-demo
DEV_UI_PORT=8090
PLATFORM_URL=http://localhost:8080
