# Retrieval MCP Server (FastAPI HTTP)
RETRIEVAL_SERVER_URL=http://localhost:8001
RETRIEVAL_TIMEOUT_SECONDS=30
RETRIEVAL_MAX_RETRIES=3

# Unified platform session (transcript + matter for all agents)
PLATFORM_SESSION_DIR=memory/sessions
SESSION_STORE_BACKEND=file
# Required when SESSION_STORE_BACKEND=postgres or MEMORY_STORE_BACKEND=postgres
DATABASE_URL=postgresql://legalai:legalai@localhost:5435/legalai
SESSION_TRANSCRIPT_LOAD_LIMIT=500
SESSION_TRANSCRIPT_MAX_TURNS=20
MEMORY_STORE_BACKEND=mcp
# Platform owns session transcript (research skips duplicate JSONL when true)
PLATFORM_OWNS_SESSION=true
# Platform owns retrieval-mcp long-term memory (prefetch + review save); review graph skips MCP when true
PLATFORM_OWNS_LONG_TERM_MEMORY=true
SESSION_MEMORY_MAX_HITS=5
# Also remove legacy research JSONL on DELETE /sessions/{thread_id}
SESSION_DELETE_LEGACY_RESEARCH_FILES=true
# Long-term memory root — must match retrieval-mcp (shared MEMORY.md)
DEEP_RESEARCH_MEMORY_DIR=memory

# Document MCP Server (contract/policy RAG — text MVP)
DOCUMENT_SERVER_URL=http://localhost:8003
DOCUMENT_TIMEOUT_SECONDS=60
DOCUMENT_MAX_RETRIES=3

# Pre-research direction selection / clarification gate (default: true)
ALLOW_CLARIFICATION=true

# Max seconds for a single agent run (full pipeline can be long). 0 = no limit.
AGENT_TIMEOUT_SECONDS=300

# API Gateway
PLATFORM_HOST=0.0.0.0
PLATFORM_PORT=8080
PLATFORM_LOG_LEVEL=INFO

# ============================================================================
# LLM credentials (consumed by the Research Agent via model_config.py)
# ============================================================================

# --- Option A: Cloud models (defaults: OpenAI + Anthropic) ------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Option B: On-prem / self-hosted (OpenAI-compatible: vLLM/Ollama/etc.) --
# LLM_BASE_URL=http://your-onprem-host:8000/v1
# LLM_API_KEY=dummy-or-real-key
# LLM_PROVIDER=openai
# LLM_MODEL=nvidia/nemotron-3-nano
# LLM_CONTEXT_LENGTH=128000
# LLM_MAX_TOKENS=8192
# LLM_MAX_TOKENS_WRITER=8192
# LLM_FINDINGS_CHAR_BUDGET=60000
# FETCH_MAX_CHARS=48000
# LLM_ENABLE_THINKING=false
# --- Option C: Mistral API (free tier on La Plateforme) -----------------------
# LLM_PROVIDER=mistralai
# LLM_API_KEY=your-mistral-api-key
# LLM_MODEL=mistral-small-latest

# Keep /query responsive when using the full research pipeline
# MAX_RESEARCHER_ITERATIONS=12
# DEEP_MAX_RESEARCHER_ITERATIONS=12
# MAX_CONCURRENT_RESEARCHERS=2
# MAX_REVIEWER_RETRIES=3
# LLM_MAX_TOKENS_WRITER=16384
# LLM_FINDINGS_CHAR_BUDGET=100000
# DEEP_LLM_FINDINGS_CHAR_BUDGET=100000
# DEEP_WRITER_MAX_TOKENS=16384
# DEEP_MIN_WRITER_COMPLETION_TOKENS=8192
# DEEP_FAST_RESEARCH_MODE=false
# DEEP_MIN_FETCHES=14
# DEEP_MIN_PRIMARY_FETCHES=10
# DEEP_BOOTSTRAP_SEARCH_QUERIES=12
# DEEP_BOOTSTRAP_MAX_FETCHES=14
# FETCH_MAX_CHARS=24000
# DEEP_FETCH_MAX_CHARS=24000
