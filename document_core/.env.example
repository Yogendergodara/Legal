DOCUMENT_STORE_BACKEND=pgvector
# Local Podman (start_postgres_podman.ps1): host port 5435
DATABASE_URL=postgresql://legalai:legalai@127.0.0.1:5435/legalai
SEARCH_BACKEND=hybrid
EMBEDDING_MODEL=nomic-ai/modernbert-embed-base
EMBEDDING_DIM=768
EMBEDDING_TRUNCATE_DIM=
# Phase 28 — 0 = disabled; exclude policies older than N days from category discovery
POLICY_STALE_DAYS=0

# LLM for ingest-time policy tagging (sync path — use separate key from review to avoid 429 quota steal)
# SYNC_LLM_API_KEY=          # preferred for sync/tagger/profiler; falls back to LLM_API_KEY
# REVIEW_LLM_API_KEY=        # set in review_agent/.env for review-only quota
# LLM_API_KEY=               # shared fallback when sync/review keys not split
# LLM_BASE_URL=https://api.mistral.ai/v1
# Ops: run policy sync off-peak (nights/weekends) when sharing one provider account.

# Phase 37C — per-parent policy category tagging at ingest (LLM default)
# Whole policy or ≥10 sections per LLM call; re-sync after changing tagger settings.
CATEGORY_TAGGER_ENABLED=true
CATEGORY_TAGGER_MODE=llm
CATEGORY_TAGGER_MODEL=mistral-small-latest
CATEGORY_TAGGER_BATCH_SIZE=10
CATEGORY_TAGGER_WHOLE_POLICY_ENABLED=true
CATEGORY_TAGGER_WHOLE_POLICY_MAX_CHARS=32000
CATEGORY_TAGGER_MAX_TAGS_PER_SECTION=5
CATEGORY_TAGGER_LLM_TIMEOUT_SECONDS=120

# Phase 37D — child chunk sizing for embeddings
CHILD_CHUNK_MAX_CHARS=700
CHILD_CHUNK_OVERLAP_SENTENCES=2
CATEGORY_SEARCH_BOOST=0.15

# Phase R0 — policy catalog profiler at ingest (LLM default)
POLICY_PROFILER_ENABLED=true
POLICY_PROFILER_MODE=llm
POLICY_PROFILER_MODEL=mistral-small-latest
POLICY_PROFILER_MAX_BODY_CHARS=4000

# Phase 16 P2 — structured ingest: send sections[] from Java sync; text-only remains dev fallback.
RETRIEVAL_RECALL_TOP_K=20
RETRIEVAL_FINAL_TOP_K=10
# Reranker — align with review deploy when MCP runs in-process
RERANKER_ENABLED=true
RERANKER_BACKEND=cross_encoder
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_MAX_PASSAGE_CHARS=2000
RERANKER_FUSION_RETRIEVAL_WEIGHT=0.10
