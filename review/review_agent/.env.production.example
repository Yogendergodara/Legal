# Production review agent — contract-only + hybrid (copy to deployment secrets manager)
# Dev/CI should keep review_agent/.env.example defaults (request + llm).

REVIEW_POLICY_SOURCE=tenant_auto
REVIEW_POLICY_SCOPE=discovered
COMPLIANCE_MODE=hybrid
CONTRACT_ROUTING_MODE=llm
CONTRACT_ROUTING_MAX_CHARS=12000
DISCOVERY_MAX_POLICIES=8
DISCOVERY_TOP_K_PER_TOPIC=3
DISCOVERY_MIN_SCORE=0.08

DOCUMENT_STORE_BACKEND=pgvector
# DATABASE_URL=postgresql://user:pass@host:5432/legal_docs

# SEARCH_BACKEND=hybrid
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
