# Section-first compliance review (production pipeline)

REVIEW_MIN_SECTION_CHARS=40
REVIEW_POLICY_SCOPE=discovered

# --- Profile: enterprise (20-section × 40+ playbooks) — DEFAULT for scale benchmark ---
# DISCOVERY_MAX_POLICIES=0
# DISCOVERY_GROUP_CAP_MODE=adaptive
# DISCOVERY_MAX_POLICY_GROUPS_CEILING=20
# SECTION_CLASSIFY_MODE=lexical_first
# COMPARE_POLICY_HIT_MODE=category_aligned

# --- Profile: cisco-small (≤8 sections, single ESG family) ---
# DISCOVERY_GROUP_CAP_MODE=fixed
# DISCOVERY_MAX_POLICY_GROUPS=6
# DISCOVERY_MAX_POLICIES=0

# Contract routing + tenant policy discovery (always on)
# CONTRACT_ROUTING_MODE=llm
DISCOVERY_GROUP_MODE=category
DISCOVERY_GROUP_CAP_MODE=adaptive
DISCOVERY_MAX_POLICY_GROUPS=6
DISCOVERY_MIN_POLICY_GROUPS=6
DISCOVERY_MAX_POLICY_GROUPS_CEILING=20
DISCOVERY_TOPIC_CAP_MODE=adaptive
DISCOVERY_MAX_TOPICS=8
DISCOVERY_MAX_TOPICS_CEILING=20
DISCOVERY_MAX_POLICIES=0
DISCOVERY_TOP_K_PER_TOPIC=5
DISCOVERY_CONTRACT_TYPE_FILTER=true
DISCOVERY_CONTRACT_TYPE_FALLBACK_MIN_HITS=4
DISCOVERY_SECTION_CATEGORY_SWEEP=true

# Section classify + compare
# lexical_first: title/boilerplate heuristics before LLM; llm_only: always classify via LLM
SECTION_CLASSIFY_MODE=lexical_first
SECTION_CLASSIFY_BATCH_RETRY_SINGLE=true
SECTION_CLASSIFY_BATCH_SIZE=4
SECTION_CLASSIFY_MAX_CHARS=12000
SECTION_COMPARE_BATCH_SIZE=8
SECTION_COMPARE_MAX_FINDINGS_PER_SECTION=4
FINDING_DEDUPE_ACROSS_POLICIES=true
SECTION_COMPARE_MAX_TOKENS=48000
SECTION_COMPARE_MAX_SECTION_CHARS=32000
SECTION_RETRIEVAL_CONCURRENCY=8
SECTION_COMPARE_CONCURRENCY=2
# Compare hit selection + quote anchoring (Phase 22 P4)
COMPARE_POLICY_HIT_MODE=category_aligned
COMPARE_MAX_POLICY_HITS=3
COMPARE_HIT_MIN_RELEVANCE_SCORE=0.35
# GROUNDING_RELAX_COMPLIANT_EMPTY_POLICY=true
COMPARE_BATCH_RETRY_SINGLE=true
COMPARE_QUOTE_ANCHOR_ENABLED=true
# Phase D — prompt-faithful token batching (rollback: COMPARE_TOKEN_BUDGET_MODE=legacy)
COMPARE_TOKEN_BUDGET_MODE=aligned
COMPARE_TOKEN_PACK_MODE=best_fit
PLAYBOOK_COMPARE_MAX_CHARS=2000
# Phase E — operator config guard (advisory only; does not disable LLM paths)
CONFIG_ADVISORY_ENABLED=true
FINAL_VERIFY_UNCLEAR_RECOMPARE_CAP_MODE=adaptive
# Production section-first profile (reference):
# SECTION_CLASSIFY_MODE=lexical_first
# OBLIGATION_ROUTING_ENABLED=false
# REVIEW_PIPELINE_MODE=serial
# LLM_GLOBAL_CONCURRENCY=2
# GUARD_PASS_NON_COMPLIANT_ONLY=true
# Phase F — accuracy paths (do not disable in production)
# POLICY_COVERAGE_ENABLED=true
# FINAL_VERIFY_UNCLEAR_RECOMPARE_ENABLED=true
# FINAL_VERIFY_COVERAGE_GATE_RECOMPARE_ENABLED=true
# SECTION_CLASSIFY_MODE=lexical_first
# Phase G — Atlassian baseline funnel interpretation (optional; empty = off)
# BASELINE_PROFILE=atlassian_v1
# High obligation_ipc_rate (~0.90) means compare LLM was withheld — extract/planner still ran
# Global LLM cap + 429 backoff (Phase 21 P0 — required for Mistral scale runs)
# PF-1A: 4 is typical for mistral-small-latest; use 3 or LLM_RATE_LIMIT_PROFILE=mistral_conservative if 429s
LLM_GLOBAL_CONCURRENCY=4
LLM_RATE_LIMIT_MAX_RETRIES=3
LLM_RATE_LIMIT_BACKOFF_BASE_SECONDS=2.0
LLM_RATE_LIMIT_BACKOFF_MAX_SECONDS=30.0
# LLM_RATE_LIMIT_PROFILE=mistral_conservative
# Phase B: dynamic retry posture — gates batch→single fan-out under quota pressure
LLM_REVIEW_POSTURE_ENABLED=true
# Phase B-RC — per-review quota reset; HOT structure split; adaptive acquire pause
# LLM_REVIEW_SCOPE_RESET_EVENTS=true
# LLM_HOT_STRUCTURE_SPLIT_MAX=12
# LLM_HOT_ACQUIRE_PAUSE_ENABLED=true
# LLM_HOT_ACQUIRE_PAUSE_MAX_SECONDS=1.5
# --- Mistral dev (429-safe) — use profile above OR uncomment individual knobs ---
# LLM_GLOBAL_CONCURRENCY=1
# SECTION_COMPARE_CONCURRENCY=1
# SECTION_CLASSIFY_BATCH_SIZE=1
# LLM_RATE_LIMIT_MAX_RETRIES=5
# LLM_RATE_LIMIT_BACKOFF_MAX_SECONDS=60
RETRIEVAL_RECALL_TOP_K=20
RETRIEVAL_FINAL_TOP_K=10
# RETRIEVAL_MAX_ATTEMPTS=3
RETRIEVAL_CATEGORY_HARD_FILTER=true
# SR-01 — meaning-first recall inside scoped policies (rollback: false → true, meaning_first → false)
# RETRIEVAL_MEANING_FIRST_ENABLED=false
# RETRIEVAL_CATEGORY_HARD_FILTER=false
# RETRIEVAL_SECTION_QUERY_MAX_CHARS=2000
# COMPARE_HIT_ALLOW_PRIMARY_FALLBACK=true
RETRIEVAL_SCOPE_FALLBACK_ON_CATEGORY_MISS=true
RETRIEVAL_PENALIZE_PREAMBLE_GENERAL=true
RETRIEVAL_SKIP_HARD_FILTER_FOR_GENERAL=true
# Phase B/G — retrieval safety (relevance gate, coverage validator, no off-topic fallback)
NAMED_POLICY_ROUTING_ENABLED=true
RETRIEVAL_RELEVANCE_GATE_ENABLED=true
RETRIEVAL_RELEVANCE_MIN_SCORE=0.2
RETRIEVAL_RELEVANCE_KEEP_BEST_FALLBACK=false
RETRIEVAL_CATEGORY_FILTER_FALLBACK=false
POLICY_COVERAGE_ENABLED=true
POLICY_COVERAGE_MIN_SCORE=0.34
POLICY_COVERAGE_REQUIRE_SPECIFIC_OVERLAP=true
COMPARE_HIT_MIN_RELEVANCE_SCORE=0.35
COMPARE_HIT_ALLOW_PRIMARY_FALLBACK=false
# SR-01 trial: true with RETRIEVAL_MEANING_FIRST_ENABLED=true
# Phase C — compare intelligence (incorporation, equivalence, topic dedupe)
INCORPORATION_GUARD_ENABLED=true
TOPIC_MISMATCH_GUARD_ENABLED=true
EQUIVALENCE_GUARD_ENABLED=true
FINDING_DEDUPE_TOPIC_CLUSTER=true
# RETRIEVAL_CATEGORY_MIN_OVERLAP=0
# DISCOVERY_WARN_ON_CAP=true

# Final gap verify (gap_llm only for no_policy sections after re-retrieve — not all INCONCLUSIVE)
FINAL_GAP_VERIFY_ENABLED=true
FINAL_GAP_RECALL_TOP_K=30
FINAL_VERIFY_UNCLEAR_RECOMPARE_ENABLED=true
FINAL_VERIFY_UNCLEAR_RECOMPARE_MAX_SECTIONS=8
FINAL_VERIFY_COVERAGE_GATE_RECOMPARE_ENABLED=true
GAP_STATUS_SUBSTANTIVE_INCONCLUSIVE=true
GAP_UPGRADE_AFTER_GAP_LLM=true

# Section coverage + contract-by-ID (Phase 10D)
ENFORCE_SECTION_COVERAGE=true
# REVIEW_REQUIRE_CONTRACT_DOCUMENT_ID=true
# REVIEW_REJECT_INLINE_POLICIES=true
# REVIEW_PREFLIGHT_ENABLED=true

# Playbook judgment + grounding (Phase 13 P4)
# PLAYBOOK_ENRICH_COMPARE=true
# PLAYBOOK_LOAD_REGISTRY=false
# GROUNDING_DOWNGRADE_NOT_DROP=true
GROUNDING_DOWNGRADE_MODE=keep_status_flag
# GROUNDING_RERUN_COVERAGE=true
# CONFLICT_EMIT_ON_SKIP=false

# Audit artifact + report synthesis (Phase 14 P5)
# ARTIFACT_INCLUDE_HIT_REFS=true
# ARTIFACT_MAX_HIT_REFS_PER_SECTION=10
# REPORT_LLM_SUMMARY=false
# REPORT_LLM_SUMMARY_MAX_TOKENS=256

# Rationale guard (Phase 15 P6 / Phase 21 P1 batch)
GUARD_PASS_ENABLED=true
GUARD_PASS_BATCH_SIZE=8
GUARD_PASS_CONCURRENCY=2
# GUARD_PASS_MODE=llm
# GUARD_PASS_NON_COMPLIANT_ONLY=true

# Document MCP (contract/policy RAG) — required for review
DOCUMENT_SERVER_URL=http://localhost:8003
# DATABASE_URL=postgresql://legalai:legalai@localhost:5435/legalai

# ============================================================================
# LLM (section classify, compare, contract routing, final gap verify)
# Copy to ".env" and set one option below.
# ============================================================================

COMPLIANCE_LLM_TEMPERATURE=0
COMPLIANCE_LLM_MAX_TOKENS=2048
COMPLIANCE_LLM_ROLE=reasoning

# --- Option A: OpenAI -------------------------------------------------------
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini

# --- Option B: On-prem / OpenAI-compatible (vLLM, Ollama, etc.) --------------
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=dummy-or-real-key
# LLM_PROVIDER=openai
# LLM_MODEL=your-model-name

# --- Option C: Mistral API (La Plateforme) — recommended for dev ------------
# Do NOT set LLM_BASE_URL for native Mistral cloud.
LLM_PROVIDER=mistralai
# REVIEW_LLM_API_KEY=        # review-only key (preferred); sync uses SYNC_LLM_API_KEY in document_core/.env
LLM_API_KEY=
# Or: MISTRAL_API_KEY=   (alias; REVIEW_LLM_API_KEY / LLM_API_KEY take precedence if set)
LLM_MODEL=mistral-small-latest
# LLM_MODEL_REASONING=mistral-large-latest

# TEMP Phase B — 3-key Mistral rotation on 429 (delete when quota fix lands)
# LLM_KEY_POOL_ENABLED=true
# LLM_API_KEYS=key-one,key-two,key-three
# When pool is on, LLM_API_KEY is ignored; leave LLM_KEY_POOL_ENABLED=false to use single key.

# Phase R1 — obligation extraction (routing still off until R2+)
OBLIGATION_ROUTING_ENABLED=false
OBLIGATION_EXTRACT_ENABLED=true
OBLIGATION_EXTRACT_BATCH_SIZE=6
OBLIGATION_EXTRACT_BATCH_RETRY_SINGLE=true
OBLIGATION_EXTRACT_MAX_SECTION_CHARS=8000

# RC-07 — promote hit-backed obligation IPC sections into F5 compare_omitted
# RECOVERY_PROMOTE_OBLIGATION_IPC_GAPS=true
SEMANTIC_PLANNER_ENABLED=true
SEMANTIC_PLANNER_BATCH_SIZE=10
SEMANTIC_PLANNER_MAX_OBLIGATION_CHARS=1500
ROUTING_ALIAS_MIN_SCORE=0.92
ROUTING_COMPARE_MIN_CONFIDENCE=0.75
ROUTING_IPC_MAX_CONFIDENCE=0.60
ROUTING_PLANNER_EXPLICIT_MENTION_CONFIDENCE_FLOOR=0.55

# IPC-3 experiment flags (default off — see PHASE_IPC3_PRODUCTION_EXECUTION_PLAN.md)
OBLIGATION_COMPARE_PROMPT_V2_ENABLED=false
IPC3_BOILERPLATE_SUBSTANTIVE_OVERRIDE_ENABLED=false
EVIDENCE_SEMANTIC_OVERLAP_ENABLED=false
EVIDENCE_MIN_SEMANTIC_OVERLAP=0.72
IPC3_CATALOG_MARGINAL_COMPARE_ENABLED=false
IPC3_CATALOG_MARGINAL_MIN_SCORE=0.22
EVIDENCE_LOW_ROUTING_RERANK_DEFER_ENABLED=false
CATALOG_MATCH_TOP_K=12
CATALOG_MATCH_MAX_CANDIDATES=8
CATALOG_MATCH_MIN_SCORE=0.25

# Phase R4/R5 — scoped obligation retrieval + evidence sufficiency
OBLIGATION_RETRIEVAL_ENABLED=true
# PF-1A: match section_retrieval_concurrency for hybrid tenants; code default remains 4
OBLIGATION_RETRIEVAL_CONCURRENCY=8
OBLIGATION_RETRIEVAL_MAX_QUERIES=4
OBLIGATION_RETRIEVAL_UNION_TOP_K=20
# PF-1B — obligation retrieval efficiency (Tier 2)
OBLIGATION_RETRIEVAL_ADAPTIVE_LADDER=true
OBLIGATION_RETRIEVAL_PARALLEL_QUERIES=true
# OBLIGATION_RETRIEVAL_WEAK_EXPAND_PROBE_ONLY=false
EVIDENCE_SUFFICIENCY_ENABLED=true
EVIDENCE_MIN_HITS=1
EVIDENCE_MIN_SCORE=0.35
EVIDENCE_MIN_CONCEPT_OVERLAP=0.15
EVIDENCE_MIN_DOC_COVERAGE=0.0
# PR-01 — precision funnel: rerank bypass + broader expand
EVIDENCE_RERANK_BYPASS_ENABLED=true
EVIDENCE_RERANK_BYPASS_MIN_CONFIDENCE=0.55
EVIDENCE_EXPAND_MAX_ROUNDS=2
EVIDENCE_EXPAND_BROADEN_MODE=both
EVIDENCE_EXPAND_MAX_EXTRA_DOCS=3
# PF-1B: parallel evidence expand jobs (set 1 to revert to serial)
EVIDENCE_EXPAND_CONCURRENCY=4

# PF-1C / PG-7 — production default serial; parallel_hybrid for pilot tenants
REVIEW_PIPELINE_MODE=serial
# Pilot: REVIEW_PIPELINE_MODE=parallel_hybrid
# REVIEW_PIPELINE_TENANT_ALLOWLIST=e2e-demo
# COMPARE_BRANCH_FAIL_OPEN=true
# OB-01 — parallel_hybrid: do not skip obligations on pre-compare section hits (PHASE_OB01020304)
OBLIGATION_RETRIEVAL_SKIP_RESOLVED_SECTIONS=false
OBLIGATION_SKIP_RESOLVED_PARALLEL_GUARD=true
OBLIGATION_RETRIEVAL_SECTION_HIT_REUSE=true
# Rollback to pre-PF-1C serial graph: REVIEW_PIPELINE_MODE=serial

# PF-1D — MCP cache + HTTP pool + compare batches (Tier 4)
MCP_SEARCH_CACHE_ENABLED=true
MCP_HTTP_MAX_KEEPALIVE_CONNECTIONS=40
MCP_HTTP_MAX_CONNECTIONS=100
# Process-global MCP in-flight cap (mirrors LLM_GLOBAL_CONCURRENCY)
MCP_GLOBAL_CONCURRENCY=6
MCP_SEMAPHORE_ACQUIRE_TIMEOUT_SECONDS=60
MCP_SEMAPHORE_ACQUIRE_WARN_SECONDS=30
# Rollback: MCP_SEARCH_CACHE_ENABLED=false SECTION_COMPARE_BATCH_SIZE=4

# Phase R6/R7 — obligation compare + routing audit (pilot: OBLIGATION_ROUTING_ENABLED=true)
OBLIGATION_COMPARE_ENABLED=true
OBLIGATION_COMPARE_BATCH_SIZE=24
OBLIGATION_COMPARE_MAX_TOKENS=48000
OBLIGATION_COMPARE_MAX_OBLIGATION_CHARS=3000
# PF-1A: ipc_fallback runs section compare on IPC-only obligation sections (skip disables section compare)
OBLIGATION_SECTION_CUTOVER_MODE=ipc_fallback

# Phase R8/R9 — golden CI gate + routing cache / pilot rollout
ROUTING_CACHE_ENABLED=true
ROUTING_CACHE_TTL_SECONDS=300
ROUTING_PLAN_CACHE_MAX_ENTRIES=500
# RC-05 — P5 golden default (use 200 only for uncapped exploration)
MAX_OBLIGATIONS_PER_REVIEW=80
MAX_OBLIGATIONS_PER_SECTION=8
OBLIGATION_CAP_MODE=round_robin
MAX_PLANNER_CALLS_PER_REVIEW=60
MAX_CATALOG_SEARCH_CALLS_PER_REVIEW=150
# Pilot only — leave empty for all tenants when OBLIGATION_ROUTING_ENABLED=true
OBLIGATION_ROUTING_TENANT_ALLOWLIST=atlassian-demo,xecurify-demo
OBLIGATION_ROUTING_TENANT_DENYLIST=e2e-demo
