# Review plan: dynamic (policy sections) or static (legacy review_dimensions.yaml)
REVIEW_PLAN_MODE=dynamic
REVIEW_MAX_CATEGORIES=30
REVIEW_MIN_SECTION_CHARS=40

# Policy catalog fetch (Phase 2) — optional external catalog URL
# POLICY_CATALOG_URL=http://localhost:9000/api/v1
POLICY_FETCH_ENABLED=true
POLICY_SEARCH_TOP_K=5

# Optional LLM filter for large playbooks (Phase 3) — off by default
REVIEW_PLAN_LLM_FILTER=false
REVIEW_PLAN_LLM_FILTER_MIN_CATEGORIES=15

# Policy scope: request | tenant | discovered (discovered = routing hits only)
REVIEW_POLICY_SCOPE=request

# Contract-first discovery (Phase 6): tenant_auto discovers policies from indexed store
# REVIEW_POLICY_SOURCE=request
# CONTRACT_ROUTING_MODE=llm
# CONTRACT_ROUTING_MAX_CHARS=12000
# DISCOVERY_MAX_POLICIES=8
# DISCOVERY_TOP_K_PER_TOPIC=3
# DISCOVERY_MIN_SCORE=0.08

# Production template: see .env.production.example (tenant_auto + hybrid)

# Compliance review mode: llm (default), lexical (CI), or hybrid (batch + prescreen)
COMPLIANCE_MODE=llm

# Hybrid mode (COMPLIANCE_MODE=hybrid)
# COMPLIANCE_BATCH_SIZE=6
# COMPLIANCE_PRESCREEN_ENABLED=true
# COMPLIANCE_PRESCREEN_COMPLIANT_MIN=0.35
# COMPLIANCE_PRESCREEN_NONCOMPLIANT_MAX=0.05
# COMPLIANCE_RETRIEVAL_SCORE_MIN=0.15
# COMPLIANCE_GAP_PASS_ENABLED=true
# COMPLIANCE_LLM_CONCURRENCY=3
# COMPLIANCE_RETRIEVAL_CONCURRENCY=10
COMPLIANCE_LLM_TEMPERATURE=0
COMPLIANCE_MAX_SECTION_CHARS=12000
COMPLIANCE_LLM_MAX_RETRIES=1
COMPLIANCE_LLM_MAX_TOKENS=2048

# Phase 10 — section-first pipeline (default legacy for backward compatibility)
# REVIEW_PIPELINE_MODE=legacy
# SECTION_CLASSIFY_MODE=lexical
# RETRIEVAL_RECALL_TOP_K=20
# RETRIEVAL_FINAL_TOP_K=10
# SECTION_COMPARE_BATCH_SIZE=2
# SECTION_COMPARE_MAX_TOKENS=48000

# LLM credentials (same env pattern as research agent)
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=openai
