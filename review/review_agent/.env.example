# Section-first compliance review (production pipeline)

REVIEW_MIN_SECTION_CHARS=40
REVIEW_POLICY_SCOPE=discovered

# --- Profile: enterprise (20-section × 40+ playbooks) — DEFAULT for scale benchmark ---
# DISCOVERY_MAX_POLICIES=0
# DISCOVERY_GROUP_CAP_MODE=adaptive
# DISCOVERY_MAX_POLICY_GROUPS_CEILING=20
# SECTION_CLASSIFY_MODE=lexical_first
# COMPARE_POLICY_HIT_MODE=category_aligned

# --- Profile: cisco-small (≤8 sections, single ESG family) ---
# DISCOVERY_GROUP_CAP_MODE=fixed
# DISCOVERY_MAX_POLICY_GROUPS=6
# DISCOVERY_MAX_POLICIES=0

# Contract routing + tenant policy discovery (always on)
# CONTRACT_ROUTING_MODE=llm
DISCOVERY_GROUP_MODE=category
DISCOVERY_GROUP_CAP_MODE=adaptive
DISCOVERY_MAX_POLICY_GROUPS=6
DISCOVERY_MIN_POLICY_GROUPS=6
DISCOVERY_MAX_POLICY_GROUPS_CEILING=20
DISCOVERY_TOPIC_CAP_MODE=adaptive
DISCOVERY_MAX_TOPICS=8
DISCOVERY_MAX_TOPICS_CEILING=20
DISCOVERY_MAX_POLICIES=0
DISCOVERY_TOP_K_PER_TOPIC=5
DISCOVERY_CONTRACT_TYPE_FILTER=true
DISCOVERY_CONTRACT_TYPE_FALLBACK_MIN_HITS=4
DISCOVERY_SECTION_CATEGORY_SWEEP=true

# Section classify + compare
SECTION_CLASSIFY_MODE=lexical_first
SECTION_CLASSIFY_BATCH_RETRY_SINGLE=true
SECTION_CLASSIFY_BATCH_SIZE=2
SECTION_CLASSIFY_MAX_CHARS=12000
SECTION_COMPARE_BATCH_SIZE=2
SECTION_COMPARE_MAX_FINDINGS_PER_SECTION=4
FINDING_DEDUPE_ACROSS_POLICIES=true
SECTION_COMPARE_MAX_TOKENS=48000
SECTION_COMPARE_MAX_SECTION_CHARS=32000
SECTION_RETRIEVAL_CONCURRENCY=8
SECTION_COMPARE_CONCURRENCY=2
# Compare hit selection + quote anchoring (Phase 22 P4)
COMPARE_POLICY_HIT_MODE=category_aligned
COMPARE_MAX_POLICY_HITS=2
COMPARE_HIT_MIN_RELEVANCE_SCORE=0.35
# GROUNDING_RELAX_COMPLIANT_EMPTY_POLICY=true
COMPARE_BATCH_RETRY_SINGLE=true
COMPARE_QUOTE_ANCHOR_ENABLED=true
# Global LLM cap + 429 backoff (Phase 21 P0 — required for Mistral scale runs)
LLM_GLOBAL_CONCURRENCY=2
LLM_RATE_LIMIT_MAX_RETRIES=3
LLM_RATE_LIMIT_BACKOFF_BASE_SECONDS=2.0
LLM_RATE_LIMIT_BACKOFF_MAX_SECONDS=30.0
# --- Mistral dev (429-safe) — uncomment if you hit rate limits during review/sync ---
# LLM_GLOBAL_CONCURRENCY=1
# SECTION_COMPARE_CONCURRENCY=1
# SECTION_CLASSIFY_BATCH_SIZE=1
# LLM_RATE_LIMIT_MAX_RETRIES=5
# LLM_RATE_LIMIT_BACKOFF_MAX_SECONDS=60
RETRIEVAL_RECALL_TOP_K=20
RETRIEVAL_FINAL_TOP_K=10
# RETRIEVAL_MAX_ATTEMPTS=3
RETRIEVAL_CATEGORY_HARD_FILTER=true
RETRIEVAL_SKIP_HARD_FILTER_FOR_GENERAL=true
# Phase B — retrieval safety (named routing, relevance gate, coverage validator)
NAMED_POLICY_ROUTING_ENABLED=true
RETRIEVAL_RELEVANCE_GATE_ENABLED=true
RETRIEVAL_RELEVANCE_MIN_SCORE=0.2
POLICY_COVERAGE_ENABLED=true
POLICY_COVERAGE_MIN_SCORE=0.34
# Phase C — compare intelligence (incorporation, equivalence, topic dedupe)
INCORPORATION_GUARD_ENABLED=true
EQUIVALENCE_GUARD_ENABLED=true
FINDING_DEDUPE_TOPIC_CLUSTER=true
# RETRIEVAL_CATEGORY_MIN_OVERLAP=0
# DISCOVERY_WARN_ON_CAP=true

# Final gap verify
FINAL_GAP_VERIFY_ENABLED=true
FINAL_GAP_RECALL_TOP_K=30
FINAL_VERIFY_UNCLEAR_RECOMPARE_ENABLED=true
FINAL_VERIFY_UNCLEAR_RECOMPARE_MAX_SECTIONS=4
GAP_STATUS_SUBSTANTIVE_INCONCLUSIVE=true
GAP_UPGRADE_AFTER_GAP_LLM=true

# Section coverage + contract-by-ID (Phase 10D)
ENFORCE_SECTION_COVERAGE=true
# REVIEW_REQUIRE_CONTRACT_DOCUMENT_ID=true
# REVIEW_REJECT_INLINE_POLICIES=true
# REVIEW_PREFLIGHT_ENABLED=true

# Playbook judgment + grounding (Phase 13 P4)
# PLAYBOOK_ENRICH_COMPARE=true
# PLAYBOOK_LOAD_REGISTRY=false
# GROUNDING_DOWNGRADE_NOT_DROP=true
# GROUNDING_RERUN_COVERAGE=true
# CONFLICT_EMIT_ON_SKIP=false

# Audit artifact + report synthesis (Phase 14 P5)
# ARTIFACT_INCLUDE_HIT_REFS=true
# ARTIFACT_MAX_HIT_REFS_PER_SECTION=10
# REPORT_LLM_SUMMARY=false
# REPORT_LLM_SUMMARY_MAX_TOKENS=256

# Rationale guard (Phase 15 P6 / Phase 21 P1 batch)
GUARD_PASS_ENABLED=true
GUARD_PASS_BATCH_SIZE=4
GUARD_PASS_CONCURRENCY=2
# GUARD_PASS_MODE=llm
# GUARD_PASS_NON_COMPLIANT_ONLY=true

# Document MCP (contract/policy RAG) — required for review
DOCUMENT_SERVER_URL=http://localhost:8003
# DATABASE_URL=postgresql://legalai:legalai@localhost:5435/legalai

# ============================================================================
# LLM (section classify, compare, contract routing, final gap verify)
# Copy to ".env" and set one option below.
# ============================================================================

COMPLIANCE_LLM_TEMPERATURE=0
COMPLIANCE_LLM_MAX_TOKENS=2048
COMPLIANCE_LLM_ROLE=reasoning

# --- Option A: OpenAI -------------------------------------------------------
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini

# --- Option B: On-prem / OpenAI-compatible (vLLM, Ollama, etc.) --------------
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=dummy-or-real-key
# LLM_PROVIDER=openai
# LLM_MODEL=your-model-name

# --- Option C: Mistral API (La Plateforme) — recommended for dev ------------
# Do NOT set LLM_BASE_URL for native Mistral cloud.
LLM_PROVIDER=mistralai
LLM_API_KEY=
# Or: MISTRAL_API_KEY=   (alias; LLM_API_KEY takes precedence if both set)
LLM_MODEL=mistral-small-latest
# LLM_MODEL_REASONING=mistral-large-latest
