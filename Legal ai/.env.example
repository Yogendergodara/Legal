# Logging
LOG_LEVEL=INFO

# Web search backend
# - duckduckgo: works out of the box, no Docker/API key (recommended for local dev)
# - open-websearch: self-hosted daemon (Docker compose)
# - legal-index: Postgres FTS over crawled docs
WEBSEARCH_BACKEND=duckduckgo
# Only used when WEBSEARCH_BACKEND=open-websearch
WEBSEARCH_BASE_URL=http://localhost:3002

# Internal tenant documents
# - file: JSON files under data/internal_docs/ (no Postgres needed)
# - postgres: pgvector + FTS (requires Docker postgres)
INTERNAL_STORAGE=file

# Page fetching
PAGE_FETCH_USER_AGENT=LegalAI-Fetcher/1.0 (contact@yourco.in)

# Per-call timeout for external/internal HTTP calls (seconds)
EXTERNAL_TIMEOUT_SECONDS=30

# Postgres + pgvector (Phase 2)
# Use localhost:5433 when running scripts from your machine (WSL/host)
# Use postgres:5432 when the app runs inside Docker (retrieval-mcp service)
DATABASE_URL=postgresql://legalai:legalai@localhost:5433/legalai

# Embeddings (local sentence-transformers model)
EMBEDDING_MODEL=nomic-ai/modernbert-embed-base
SEMANTIC_HYBRID_ALPHA=0.5

# Crawler worker (separate process)
CELERY_BROKER_URL=redis://redis:6379/0
S3_BUCKET=legalai-crawler
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
