# ============================================================================
# LLM configuration
# Copy this file to ".env" and fill in your values.
# ============================================================================

# --- Legal ai Retrieval MCP server ------------------------------------------
# Start the server from the Legal ai project:
#   uvicorn mcp.retrieval_server.main:app --port 8001
RETRIEVAL_SERVER_URL=http://localhost:8001
RETRIEVAL_TIMEOUT_SECONDS=30
RETRIEVAL_MAX_RETRIES=3

# Fetch discipline and verification tuning
# MIN_FETCHES=2
# MIN_PRIMARY_FETCHES=1
# FETCH_MAX_CHARS=24000
# MAX_REVIEWER_RETRIES=2

# Skip the LLM clarification gate and proceed straight to research (default: false)
ALLOW_CLARIFICATION=false

# Long-term legal memory store (MEMORY.md + linked files). save_memory/search_memory
# route to the Legal ai MCP server, which must point DEEP_RESEARCH_MEMORY_DIR at
# this SAME absolute path so the load_memory node and the MCP server share one store.
# DEEP_RESEARCH_MEMORY_DIR=/abs/path/to/Legal_AI_FULL/memory

# --- Option A: Cloud models (default, no extra config needed) ---------------
# Just provide the provider keys and the built-in defaults are used
# (openai:gpt-4.1 for reasoning, anthropic:claude-sonnet-4 for research, etc.)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Option B: On-prem / self-hosted LLM (OpenAI-compatible) ----------------
# Point the WHOLE project at your on-prem model with no code changes.
# Works with vLLM, Ollama, LM Studio, TGI, etc. that expose an OpenAI API.
#
# LLM_BASE_URL=http://your-onprem-host:8000/v1
# LLM_API_KEY=dummy-or-real-key
# LLM_PROVIDER=openai
# LLM_MODEL=your-model-name          # e.g. llama-3.1-70b-instruct
#
# Optional: override just one role instead of all of them.
# LLM_MODEL_SUMMARIZER=your-small-fast-model
# LLM_MODEL_REASONING=your-big-model
# LLM_MODEL_SUPERVISOR=your-big-model
#
# For fixed-context on-prem models:
# LLM_CONTEXT_LENGTH=128000
# LLM_MAX_TOKENS=8192
# LLM_MAX_TOKENS_WRITER=8192
# LLM_FINDINGS_CHAR_BUDGET=60000
# FETCH_MAX_CHARS=48000
# LLM_ENABLE_THINKING=false

# --- Memory storage (file-based) --------------------------------------------
# Where session transcripts + long-term MEMORY.md are stored.
# Defaults to "./memory" if unset.
# DEEP_RESEARCH_MEMORY_DIR=memory

# Compaction tuning (long-chat memory conservation)
# DEEP_RESEARCH_COMPACT_THRESHOLD=12
# DEEP_RESEARCH_KEEP_RECENT=6

# --- Optional: LangSmith tracing --------------------------------------------
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=deep_research_from_scratch
